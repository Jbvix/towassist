# --- TowAssist: variáveis de ambiente (exemplo) ---
# Copie para .env e preencha os valores reais. NUNCA versione o .env.

# xAI (somente backend/Netlify Functions — NUNCA no navegador)
# Chave única usada para o chat (Grok) e para cunhar tokens de voz (Realtime).
XAI_API_KEY=xai-sua-chave-aqui
# Modelo de chat (Responses API /v1/responses). Ajuste ao da sua conta.
XAI_MODEL=grok-4.20-0309-non-reasoning
XAI_VOICE_MODEL=grok-voice-latest
XAI_VOICE=leo

# RAG dos manuais (Sprint 6) — IDs das Collections da xAI.
# Gere com: XAI_MANAGEMENT_API_KEY=... node --experimental-strip-types scripts/build-collections.ts
# e cole os IDs aqui (e no painel do Netlify). Se vazios, o KRATOS responde sem citações.
XAI_COLLECTION_KRAAIJVELD=
XAI_COLLECTION_IBERCISA=

# Chave de MANAGEMENT (apenas para rodar a ingestão localmente; NÃO usar no runtime).
XAI_MANAGEMENT_API_KEY=

# Backend / BFF
PORT=3000

# Frontend
VITE_API_BASE_URL=http://localhost:3000
